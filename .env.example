# ============================================================================
# AI-Powered Alcohol Label Verification App
# Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values

# ============================================================================
# Environment
# ============================================================================
NODE_ENV=development
# Options: development, staging, production

# ============================================================================
# Application URLs
# ============================================================================
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
API_PORT=5000

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://labeladmin:labelverifier_secure_pwd@localhost:5432/label_verifier_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=labeladmin
DB_PASSWORD=labelverifier_secure_pwd
DB_NAME=label_verifier_db

# Database connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false
# Set to true in production: DB_SSL=true

# ============================================================================
# Redis Configuration (for batch job queuing)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password (if required)

# ============================================================================
# Google Cloud Vision API
# ============================================================================
GOOGLE_CLOUD_PROJECT_ID=your-project-id
# Download JSON key from Google Cloud Console
GOOGLE_CLOUD_KEY_FILE=./credentials.json
VISION_API_CONFIDENCE_THRESHOLD=0.7
# Minimum confidence (0-1) for extracted text fields

# ============================================================================
# AWS S3 Configuration (for label image storage)
# ============================================================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=label-verifier-uploads
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
# Alternative: use IAM role in production instead of keys
AWS_S3_UPLOAD_EXPIRY=3600
# How long (seconds) signed S3 URLs are valid

# ============================================================================
# Authentication & Security
# ============================================================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_please
JWT_EXPIRY=24h
# Format: 24h, 7d, etc. or milliseconds

# OAuth 2.0 (for government SSO integration)
OAUTH_ENABLED=false
OAUTH_CLIENT_ID=your_client_id
OAUTH_CLIENT_SECRET=your_client_secret
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================================================
# Batch Processing Configuration
# ============================================================================
MAX_BATCH_SIZE=500
# Maximum labels per batch upload
BATCH_TIMEOUT=600
# Timeout (seconds) for batch processing job
CONCURRENT_BATCH_JOBS=5
# Number of labels to process in parallel

# ============================================================================
# Label Validation Rules
# ============================================================================
REQUIRE_EXACT_BRAND_MATCH=false
# If true, brand name must be 100% match; if false, fuzzy matching allowed
REQUIRE_EXACT_WARNING_MATCH=true
# Government warning must always be exact
BRAND_NAME_FUZZY_RATIO=0.85
# Threshold for brand name fuzzy matching (0-1)

# ============================================================================
# Logging & Monitoring
# ============================================================================
LOG_LEVEL=info
# Options: error, warn, info, debug, trace
LOG_FORMAT=json
# Options: json, pretty
SENTRY_DSN=
# Leave empty for development, set in production for error tracking

# ============================================================================
# Email Configuration (for compliance notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@ttb-label-verifier.gov
# Used for compliance alerts, batch completion notifications

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
# Time window (ms) for rate limiting - default 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window per user

# ============================================================================
# Feature Flags (for gradual rollout)
# ============================================================================
FEATURE_BATCH_PROCESSING=true
FEATURE_AUTO_APPROVAL=false
# Auto-approve if confidence > 95%
FEATURE_ADVANCED_OCR=true
# Enable angle correction and shadow removal

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
# Comma-separated list of allowed origins

# ============================================================================
# File Upload Configuration
# ============================================================================
MAX_FILE_SIZE_MB=50
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
# Comma-separated MIME types

# ============================================================================
# Compliance & Audit
# ============================================================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555
# 7 years for federal compliance
ENCRYPTION_KEY=your_32_char_encryption_key_here
# Used for encrypting sensitive audit data at rest

# ============================================================================
# Development Only
# ============================================================================
DEBUG=label-verifier:*
# Enable verbose debugging (npm package: debug)
MOCK_VISION_API=false
# Use fake OCR responses instead of real Vision API
SEED_DATABASE=false
# Populate with test data on startup
