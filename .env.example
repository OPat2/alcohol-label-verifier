# ============================================================================
# AI-Powered Alcohol Label Verification App — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values

# ============================================================================
# Environment
# ============================================================================
NODE_ENV=development
# Options: development, production, test

# ============================================================================
# Application
# ============================================================================
API_PORT=5000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info
# Options: error, warn, info, debug

# ============================================================================
# Authentication & Security
# ============================================================================
JWT_SECRET=replace-this-with-a-strong-random-secret-at-least-32-chars
JWT_EXPIRY=24h

# ============================================================================
# OCR / Vision
# ============================================================================
MOCK_VISION_API=false
# Set to "true" in tests or when you want to use fake OCR responses

# ============================================================================
# Batch Processing
# ============================================================================
MAX_BATCH_SIZE=300
# Maximum number of labels per batch job

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# Deployment (for docker-compose)
# ============================================================================
# VITE_API_URL=/api   # Set in frontend build for reverse-proxy setups
