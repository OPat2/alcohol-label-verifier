{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "../",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": ["src/*"],
      "@label-verifier/shared": ["../shared/src/index.ts"],
      "@label-verifier/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "../shared/src/**/*"]
}
